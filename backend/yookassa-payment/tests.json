{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Create payment without amount",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "create",
        "description": "Test"
      },
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "unknown"
      },
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Webhook canceled event",
      "method": "POST",
      "path": "/",
      "body": {
        "event": "payment.canceled",
        "object": {"id": "test-cancel-123", "status": "canceled", "amount": {"value": "100.00"}, "metadata": {}}
      },
      "expectedStatus": 200,
      "expectedBody": {"status": "logged"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get payments without user_id",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get payments for user",
      "method": "GET",
      "path": "/?user_id=1",
      "expectedStatus": 200,
      "expectedBody": {"total": 0},
      "bodyMatcher": "partial"
    }
  ]
}